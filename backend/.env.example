# ESP32-CAM Configuration
ESP32_CAM_URL=http://192.168.1.22:81

# Backend Configuration
BACKEND_URL=http://localhost:5000

# Face Recognition Thresholds
CONFIDENCE_THRESHOLD=0.6

# Memory Management
MAX_ALERTS=1000
MAX_SNAPSHOTS=200

# Image Quality Thresholds (adjust based on your ESP32-CAM JPEG quality settings)
BLUR_THRESHOLD=40

# Performance
FACE_RECOGNITION_TIMEOUT=3.0
